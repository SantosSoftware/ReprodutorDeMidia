{
  "name": "auralis",
  "version": "1.0.0",
  "description": "Auralis — reprodutor de média (desktop / Electron)",
  "author": "Santos Software",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "npm run dev --prefix src",
    "dev:server": "npm run dev --prefix server",
    "electron": "concurrently -n server,vite,electron -c blue,green,yellow \"npm run dev --prefix server\" \"npm run dev --prefix src\" \"wait-on http://localhost:5173 tcp:127.0.0.1:3001 && cross-env ELECTRON_DEV=1 electron .\"",
    "build:client": "npm run build --prefix src",
    "build:server": "npm run build --prefix server",
    "build": "npm run build:server && npm run build:client",
    "dist": "node scripts/ensure-fanart-config.mjs && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "dev:electron": "npm run electron"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.auralis.app",
    "productName": "Auralis",
    "artifactName": "${productName}-${version}-Setup.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "server/dist",
        "to": "server/dist"
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      },
      {
        "from": "src/dist",
        "to": "client-dist"
      },
      {
        "from": "config/fanart-config.json",
        "to": "fanart-config.json"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Auralis"
    }
  }
}
