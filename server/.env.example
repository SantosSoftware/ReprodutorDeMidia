# Copie para .env e preencha. O ficheiro .env não deve ser commitado.

# Fanart.tv — fotos de artista por MBID do MusicBrainz
# https://fanart.tv/get-a-api-key/
FANART_TV_API_KEY=
# Opcional, se a API do Fanart pedir
# FANART_TV_CLIENT_KEY=

# MusicBrainz (obrigatório para políticas de uso)
# MUSICBRAINZ_USER_AGENT=MyMediaPlayer/1.0 (seu-email@exemplo.com)

# TheAudioDB (opcional; por defeito usa chave pública de teste)
# THEAUDIODB_API_KEY=1
